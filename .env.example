# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
LOG_LEVEL=info
REQUEST_SIZE_LIMIT=100kb
# Set to 1 if running behind a reverse proxy (nginx, etc.) to trust X-Forwarded-For
TRUST_PROXY=0
# Comma-separated list of allowed CORS origins (e.g. https://app.example.com,http://localhost:3001)
# Leave blank to allow all origins in development
CORS_ORIGINS=
# Enable Swagger API documentation (defaults to enabled in development, disabled in production)
# Set to 'true' to enable in production, 'false' to disable everywhere
ENABLE_SWAGGER=true
# Enable Bull Board queue dashboard (defaults to enabled in development, disabled in production)
# Set to 'true' to enable in production, 'false' to disable everywhere
ENABLE_BULL_BOARD=true

# Frontend base URL used to build join links (no trailing slash)
FRONTEND_URL=https://app.example.com

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:199900@localhost:5432/hajorAppV2
# DB_POOL is informational only; tune connection_limit in DATABASE_URL for Prisma pooling
DB_POOL=10
PRISMA_POOL=default
# How many days before soft-deleted records are permanently purged (default: 90)
SOFT_DELETE_RETENTION_DAYS=90

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=changeme
# Access token lifetime in seconds (default: 900 = 15 min)
ACCESS_TOKEN_TTL_SECONDS=90000
# Refresh token lifetime in days (default: 30)
REFRESH_TOKEN_DAYS=30
# Login rate-limit window in seconds (default: 300)
LOGIN_TTL_SECONDS=300
# Max login attempts per window (default: 10)
LOGIN_MAX_PER_TTL=10

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT=100
RATE_TTL=60

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=ChangeMe123!
# Comma-separated user IDs that can access fraud/admin endpoints without a role guard
ADMIN_USER_IDS=

# ─── Users / Security ────────────────────────────────────────────────────────
# bcrypt salt rounds (default: 12)
BCRYPT_SALT_ROUNDS=12

# ─── KYC provider ────────────────────────────────────────────────────────────
KYC_PROVIDER_URL=https://sandbox.example-kyc.com/verify
KYC_PROVIDER_KEY=your_sandbox_api_key
# Bypass KYC validation for development/testing (set to 'true' to allow signup without real provider)
# Remove or set to 'false' before going to production
KYC_BYPASS=true

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
# Override base URL for sandbox/testing (default: https://api.paystack.co)
PAYSTACK_BASE_URL=https://api.paystack.co

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@example.com

# ─── Background jobs / Workers ───────────────────────────────────────────────
# Set to true to disable in-process BullMQ workers (use separate worker processes instead)
DISABLE_IN_APP_WORKERS=false
# Cron expression for Paystack reconciliation job (default: every 5 min)
RECONCILE_CRON=*/5 * * * *
# Cron expression for late-fee calculation job (default: midnight daily)
LATEFEE_CRON=0 0 * * *
REPROVISION_CRON=*/30 * * * *
# How many seconds before a contribution due date to send a reminder (default: 86400 = 1 day)
REMINDER_LEAD_SECONDS=86400

# ─── Monitoring / Alerting ───────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Slack/Discord/webhook URL for critical system alerts (optional)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_MS=5000
PAYSTACK_PREFERRED_BANK=wema-bank
# Dev only: set to any non-empty value to simulate a Paystack failure and observe BullMQ retries.
# Remove or leave blank in production.
PAYSTACK_DEV_SIMULATE=sim