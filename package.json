{
  "name": "hajor-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "reconcile:paystack": "ts-node ./src/worker/reconciliation.worker.ts",
    "start": "node dist/main.js",
    "start:prod": "prisma migrate deploy && node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "npx nest build",
    "migrate:deploy": "prisma migrate deploy",
    "start:workers": "node dist/worker/payments.worker.js & node dist/worker/notifications.worker.js",
    "dev:all": "npm run build && cross-env DISABLE_IN_APP_WORKERS=true concurrently \"node dist/main.js\" \"node dist/worker/payments.worker.js\" \"node dist/worker/notifications.worker.js\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts",
    "generate:openapi": "ts-node scripts/generate-openapi.ts",
    "backfill:payout-order": "ts-node prisma/scripts/backfill-payout-order.ts",
    "backfill:payout-order:apply": "ts-node prisma/scripts/backfill-payout-order.ts --apply"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^4.0.0",
    "@railway/cli": "^4.44.0",
    "@sentry/node": "^7.0.0",
    "axios": "^1.14.0",
    "bcrypt": "^5.0.1",
    "bullmq": "^1.79.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "helmet": "^6.0.0",
    "ioredis": "^5.3.2",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.10.0",
    "pino": "^8.0.0",
    "pino-http": "^7.0.0",
    "prom-client": "^14.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "@bull-board/api": "^6.20.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "pino-pretty": "^13.1.3",
    "prisma": "^4.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
